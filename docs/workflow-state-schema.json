{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-engineering-skills/workflow-state.schema.json",
  "title": "AI Engineering Skills Workflow State",
  "type": "object",
  "required": [
    "schemaVersion",
    "workflow",
    "runPath",
    "executionMode",
    "status",
    "currentStage",
    "nextAction",
    "codeEditsAllowed",
    "riskLevel",
    "riskReason",
    "confirmationRequired",
    "rollbackRequired",
    "updatedAt"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "workflow": {
      "type": "string",
      "enum": [
        "codebase-orientation",
        "code-review-triage",
        "debug-root-cause",
        "api-contract-design",
        "data-migration-planning",
        "software-delivery-pipeline"
      ]
    },
    "runPath": {
      "type": "string",
      "minLength": 1
    },
    "sourceArtifact": {
      "type": ["string", "null"]
    },
    "domainModules": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["java-spring-microservice"]
      },
      "default": []
    },
    "executionMode": {
      "type": "string",
      "enum": ["lightweight", "standard", "full"]
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "blocked",
        "pending_human_confirmation",
        "handoff_ready",
        "completed",
        "abandoned"
      ]
    },
    "currentStage": {
      "type": "string",
      "minLength": 1
    },
    "latestDocument": {
      "type": ["string", "null"]
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "codeEditsAllowed": {
      "type": "boolean"
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "riskReason": {
      "type": "string"
    },
    "confirmationRequired": {
      "type": "boolean"
    },
    "rollbackRequired": {
      "type": "boolean"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "selectedScope": {
      "type": ["string", "null"]
    },
    "affectedServices": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "affectedControllers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "affectedFeignClients": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "affectedTables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "affectedCollections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "affectedTopics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "affectedConfigKeys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "rollbackPlan": {
      "type": ["string", "null"],
      "default": null
    },
    "verificationPlan": {
      "type": ["string", "null"],
      "default": null
    },
    "verificationRequired": {
      "type": "boolean",
      "default": false
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    }
  }
}
