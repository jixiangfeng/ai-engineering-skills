{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-engineering-skills/artifact-metadata-schema.json",
  "title": "AI Engineering Skills Artifact Metadata",
  "type": "object",
  "required": [
    "workflow",
    "runId",
    "executionMode",
    "stage",
    "status",
    "source",
    "allowsCodeEdit",
    "nextAction"
  ],
  "additionalProperties": false,
  "properties": {
    "workflow": {
      "enum": [
        "<workflow>",
        "workflow-bootstrap",
        "codebase-orientation",
        "code-review-triage",
        "debug-root-cause",
        "api-contract-design",
        "data-migration-planning",
        "software-delivery-pipeline"
      ]
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "runPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^workflow/"
    },
    "executionMode": {
      "enum": ["lightweight", "standard", "full"]
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "not_started",
        "in_progress",
        "blocked",
        "pending_human_confirmation",
        "handoff_ready",
        "completed",
        "abandoned"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "allowsCodeEdit": {
      "type": "boolean"
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "fromWorkflow": {
      "type": "string",
      "minLength": 1
    },
    "toWorkflow": {
      "type": "string",
      "minLength": 1
    },
    "selectedItems": {
      "type": "array"
    },
    "verificationRequired": {
      "type": "boolean"
    },
    "sourceArtifact": {
      "type": "string",
      "minLength": 1
    }
  }
}
